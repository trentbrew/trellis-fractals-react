# Remote hosted demo — copy to .env.local (dev) or set in Vercel (production).
# After `pnpm run smoke:deploy`, values also live in `.trellis-db.json`.

# Server rewrite target (HTTP proxy /api/trellis → room node). Set at build time on Vercel.
TRELLIS_URL=https://playground-next-demo-yourorg.sprites.app

# Client WebSocket + SDK origin (public — demo API key only)
NEXT_PUBLIC_TRELLIS_URL=https://playground-next-demo-yourorg.sprites.app
NEXT_PUBLIC_TRELLIS_API_KEY=spk_…

# Optional — cross-browser presence on localhost (same-browser tabs use BroadcastChannel when relay is down)
# `just run` starts the relay; or run `just presence-relay` in another terminal.
# NEXT_PUBLIC_PRESENCE_RELAY_URL=ws://localhost:8231/rt
